# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# 64 hex chars (32 bytes). Generate: openssl rand -hex 32
BOT_ENCRYPTION_KEY=

# MRPH Global production endpoints
CHAIN_ID=mrphglobal-1
ADDR_PREFIX=mrph
DENOM=umrph
DISPLAY_DENOM=MRPH
DENOM_DECIMALS=6
LCD_URL=http://127.0.0.1:1317
RPC_URL=http://127.0.0.1:26657
GAS_PRICE=0.2umrph
GAS_LIMIT=200000

# Wallet data directory (created automatically)
DATA_DIR=/opt/mrph-telegram-bot/data
